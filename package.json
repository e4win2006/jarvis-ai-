{
  "name": "jarvis",
  "private": true,
  "version": "1.0.0",
  "description": "JARVIS - Personal AI Assistant by Edwin Tom Joseph",
  "author": "Edwin Tom Joseph",
  "type": "module",
  "main": "main.cjs",
  "scripts": {
    "dev": "concurrently \"vite\" \"npm run dev --prefix server\"",
    "build": "tsc -b && vite build && npm run build --prefix server",
    "lint": "oxlint",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"npm run dev --prefix server\" \"electron .\"",
    "electron:build": "npm run build && electron-builder",
    "predeploy": "vite build",
    "deploy": "npx gh-pages -d dist"
  },
  "dependencies": {
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^9.1.2",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "gh-pages": "^6.3.0",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
